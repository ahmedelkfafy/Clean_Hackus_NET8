<Page x:Class="Clean_Hackus_NET8.UI.Pages.Overlays.RequestsManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Requests Manager">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Search Requests Manager" FontTypography="Title" />
            <ui:TextBlock Text="Manage active IMAP search queries and filter domains." 
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Managed Requests DataGrid -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <ui:DataGrid ItemsSource="{Binding SearchRequests}" 
                         AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended">
                <ui:DataGrid.Columns>
                    <DataGridTextColumn Header="Query String" Binding="{Binding Query}" Width="*" />
                    <DataGridTextColumn Header="Filter Type" Binding="{Binding FilterType}" Width="150" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="100" />
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Border>

        <!-- Tooling Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="1" Margin="0,0,8,0" Content="Add Request" Icon="{ui:SymbolIcon Symbol=Add24}" Command="{Binding AddRequestCommand}" />
            <ui:Button Grid.Column="2" Margin="0,0,8,0" Content="Remove Selected" Appearance="Danger" Command="{Binding RemoveRequestCommand}" />
            <ui:Button Grid.Column="3" Content="Clear All" Appearance="Secondary" Command="{Binding ClearRequestsCommand}" />
        </Grid>
    </Grid>
</Page>
