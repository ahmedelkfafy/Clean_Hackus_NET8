<Page x:Class="Clean_Hackus_NET8.UI.Pages.Overlays.ProxyLoaderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Proxy Manager">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="Load Proxies" FontTypography="Title" />
            <ui:TextBlock Text="Import proxies for anonymous threaded checking. Supported formats: HTTP/S, SOCKS4, SOCKS5." 
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Proxy List Viewer Settings -->
            <Border Grid.Column="0" Margin="0,0,16,0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel>
                    <ui:TextBox PlaceholderText="Enter proxy list link (API Auto-Update)" Text="{Binding ProxyLink}" Margin="0,0,0,16" />
                    
                    <ui:CardControl Margin="0,0,0,8">
                        <ui:CardControl.Header>
                            <ui:TextBlock Text="Proxy Refresh Timeout (Minutes)" FontTypography="BodyStrong" />
                        </ui:CardControl.Header>
                        <ui:NumberBox Value="{Binding RefreshTimeout}" Minimum="1" Maximum="60" Width="100" />
                    </ui:CardControl>

                    <ui:CardControl>
                        <ui:CardControl.Header>
                            <ui:TextBlock Text="Identify Proxy Types Automatically" FontTypography="BodyStrong" />
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding AutoDetectType}" />
                    </ui:CardControl>
                </StackPanel>
            </Border>

            <!-- Protocol / Import Controls -->
            <StackPanel Grid.Column="1" Margin="0,0,0,12">
                <ui:TextBlock Text="Source Import" FontTypography="Subtitle" />
                <ui:Button Content="Load from File" Icon="{ui:SymbolIcon Symbol=Folder24}" Command="{Binding LoadFromFileCommand}" HorizontalAlignment="Stretch" />
                <ui:Button Content="Load from Clipboard" Icon="{ui:SymbolIcon Symbol=Clipboard24}" Command="{Binding LoadFromClipboardCommand}" HorizontalAlignment="Stretch" />
                <ui:Button Content="Import from Link" Appearance="Primary" Icon="{ui:SymbolIcon Symbol=Link24}" Command="{Binding LoadFromLinkCommand}" HorizontalAlignment="Stretch" Margin="0,16,0,0" />

                <ui:TextBlock Text="Proxy Status" FontTypography="Subtitle" Margin="0,24,0,8" />
                <ui:Card>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <ui:SymbolIcon Symbol="Server24" />
                        <StackPanel>
                            <TextBlock Text="Total Loaded:" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding TotalProxiesLoaded}" FontWeight="Bold" FontSize="16" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
