<ui:FluentWindow x:Class="Clean_Hackus_NET8.UI.Views.MainView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:viewmodels="clr-namespace:Clean_Hackus_NET8.UI.ViewModels"
                 Title="Hackus Mail Checker (.NET 8 core)"
                 Width="1050" Height="750"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid>
        <ui:TitleBar Title="Hackus Mail Checker (.NET 8 Core)" />

        <ui:NavigationView Margin="0,32,0,0" PaneDisplayMode="Left" SelectedPageIndex="0">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Checker" Icon="{ui:SymbolIcon Checkmark24}" TargetPageType="{x:Type Page}" />
                <ui:NavigationViewItem Content="Proxies" Icon="{ui:SymbolIcon Globe24}" TargetPageType="{x:Type Page}" />
                <ui:NavigationViewItem Content="Results" Icon="{ui:SymbolIcon Folder24}" TargetPageType="{x:Type Page}" />
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type Page}" />
            </ui:NavigationView.FooterMenuItems>
            
            <ui:NavigationView.Content>
                <!-- Main Checker Dashboard View -->
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="16">
                        <ui:CardAction Height="120" Padding="20">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Checked Items" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding Statistics.CheckedStrings}" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardAction>

                        <ui:CardAction Height="100">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="#4CAF50" FontSize="28" />
                                <TextBlock Grid.Column="1" Text="Good/Hits" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="16" />
                                <TextBlock Grid.Column="2" Text="{Binding Statistics.Good}" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" />
                            </Grid>
                        </ui:CardAction>

                        <ui:CardAction Height="100">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="DismissCircle24" Foreground="#F44336" FontSize="28" />
                                <TextBlock Grid.Column="1" Text="Bads" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="16" />
                                <TextBlock Grid.Column="2" Text="{Binding Statistics.Bad}" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" />
                            </Grid>
                        </ui:CardAction>
                        
                        <ui:CardAction Height="100">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="Mail24" Foreground="#2196F3" FontSize="28" />
                                <TextBlock Grid.Column="1" Text="Found Mails" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="16" />
                                <TextBlock Grid.Column="2" Text="{Binding Statistics.Found}" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" />
                            </Grid>
                        </ui:CardAction>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Content="Start" Appearance="Primary" Command="{Binding StartCommand}" HorizontalAlignment="Stretch" />
                            <ui:Button Grid.Column="2" Content="Stop" Appearance="Danger" Command="{Binding StopCommand}" HorizontalAlignment="Stretch" />
                        </Grid>
                    </StackPanel>
                    
                    <ui:DataGrid Grid.Column="1" Margin="24,0,0,0" 
                                 HeadersVisibility="Column" 
                                 AutoGenerateColumns="False" 
                                 CanUserAddRows="False"
                                 ItemsSource="{Binding Statistics.RecentLogs}">
                        <ui:DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="120" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                        </ui:DataGrid.Columns>
                    </ui:DataGrid>
                </Grid>
            </ui:NavigationView.Content>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
