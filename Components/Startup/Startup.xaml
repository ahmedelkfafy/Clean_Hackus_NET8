<ui:FluentWindow x:Class="Clean_Hackus_NET8.Components.Startup.Startup"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Startup" Width="600" Height="400"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <ui:TitleBar Title="Hackus Mail Checker (.NET 8 Core)" />

        <Grid Margin="24,48,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,24">
                <ui:SymbolIcon Symbol="Shield24" FontSize="64" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Authentication required" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0" />

                <StackPanel Width="300" Margin="0,24,0,0">
                    <ui:TextBox PlaceholderText="Username" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <PasswordBox x:Name="PasswordField" Margin="0,0,0,12" PasswordChanged="PasswordField_PasswordChanged" />
                    <ui:Button Content="Authenticate" Appearance="Primary" Command="{Binding LoginCommand}" HorizontalAlignment="Stretch" />
                </StackPanel>
                
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" HorizontalAlignment="Center" Margin="0,12,0,0"
                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:ProgressRing IsIndeterminate="True" Visibility="{Binding IsAuthorizing, Converter={StaticResource BooleanToVisibilityConverter}}" Width="24" Height="24" />
                <TextBlock Grid.Column="1" Text="{Binding Status}" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="2" Text="{Binding CurrentVersion}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorDisabledBrush}" />
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
