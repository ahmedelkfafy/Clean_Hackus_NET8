<ui:FluentWindow x:Class="Clean_Hackus_NET8.Components.Viewer.ViewerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="Mail Viewer" Width="1050" Height="720"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Mail Viewer" />

        <Grid Grid.Row="1" Margin="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="180" />
                </Grid.RowDefinitions>

                <!-- Quick Connect: just paste email:password -->
                <Border Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <ui:TextBlock Text="Quick Connect" FontTypography="BodyStrong" Margin="0,0,0,6" />
                        <ui:TextBox PlaceholderText="Paste email:password" Text="{Binding QuickConnectInput, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <!-- Load Hits -->
                <ui:Button Grid.Row="1" Content="Load from Good.txt" Icon="{ui:SymbolIcon FolderOpen24}"
                           Command="{Binding LoadHitsCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,8" Appearance="Secondary" />

                <!-- Account List -->
                <ui:TextBlock Grid.Row="2" Text="Accounts" FontTypography="Subtitle" Margin="0,0,0,4" />
                <ListBox Grid.Row="3"
                         ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding SelectedAccount}"
                         Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Address}" FontSize="12" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Folder Tree -->
                <ui:TextBlock Grid.Row="4" Text="Folders" FontTypography="Subtitle" Margin="0,8,0,4" />
                <ListBox Grid.Row="5"
                         ItemsSource="{Binding Folders}"
                         SelectedItem="{Binding SelectedFolder}"
                         Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="12" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Right Panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" PlaceholderText="Search emails (subject, from, body)..." Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="1" Content="Search" Icon="{ui:SymbolIcon Search24}" Command="{Binding SearchCommand}" Appearance="Primary" />
                </Grid>

                <!-- Message List -->
                <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Margin="0,0,0,8">
                    <ui:DataGrid ItemsSource="{Binding Messages}"
                                 SelectedItem="{Binding SelectedMessage}"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="True"
                                 CanUserAddRows="False"
                                 HeadersVisibility="Column">
                        <ui:DataGrid.Columns>
                            <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="*" />
                            <DataGridTextColumn Header="From" Binding="{Binding From}" Width="200" />
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="140" />
                        </ui:DataGrid.Columns>
                    </ui:DataGrid>
                </Border>

                <!-- WebView2 Email Body -->
                <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                    <wv2:WebView2 x:Name="EmailWebView" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
