<UserControl x:Class="Clean_Hackus_NET8.Components.Viewer.Views.Tabs.ImapTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Mailbox Folder List -->
        <Border Grid.Column="0" Margin="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <StackPanel>
                <ui:TextBlock Text="Mailbox Folders" FontTypography="Subtitle" Margin="16,16,16,8" />
                <ListView ItemsSource="{Binding Folders}" SelectedItem="{Binding SelectedFolder}" BorderThickness="0" Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,4">
                                <ui:SymbolIcon Symbol="Folder24" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <!-- Messages & Viewer -->
        <Grid Grid.Column="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <!-- Message List -->
            <ui:DataGrid Grid.Row="0" Margin="0,0,0,8" 
                         ItemsSource="{Binding Messages}" 
                         SelectedItem="{Binding SelectedMessage}"
                         AutoGenerateColumns="False" CanUserAddRows="False">
                <ui:DataGrid.Columns>
                    <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="*" />
                    <DataGridTextColumn Header="From" Binding="{Binding From}" Width="200" />
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="150" />
                </ui:DataGrid.Columns>
            </ui:DataGrid>

            <!-- HTML Message Body Viewer (WebView2) -->
            <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <wv2:WebView2 Name="MessageWebView" Source="{Binding CurrentHtmlContent}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
